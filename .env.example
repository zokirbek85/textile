# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=textile_db
POSTGRES_USER=textile_user
POSTGRES_PASSWORD=textile_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_pass@redis:6379/2

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Superuser Bootstrap ──────────────────────────────────────────────────────
DJANGO_SUPERUSER_EMAIL=admin@textile.uz
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=Admin1234!

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─── Storage (optional — local by default) ────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
